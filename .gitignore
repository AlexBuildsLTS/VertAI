# ==============================================================================
# NORTH STUDIO — ENTERPRISE .GITIGNORE
# Stack: Expo v55, React Native, Supabase, Deno, NativeWind, Skia
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DEPENDENCIES & PACKAGE MANAGERS
# ------------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnp.cjs

# Package Manager Debug Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 2. EXPO & REACT NATIVE CACHES
# ------------------------------------------------------------------------------
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# EAS (Expo Application Services) Local State
.eas/
# Note: eas.json is NOT ignored, it is required for build configurations.

# ------------------------------------------------------------------------------
# 3. NATIVE DIRECTORIES (Auto-generated via Prebuild)
# ------------------------------------------------------------------------------
# These folders are ephemeral in a Managed Expo workflow. They are generated
# via `npx expo prebuild` and should never be committed.
/ios
/android
.kotlin/
*.orig.*

# ------------------------------------------------------------------------------
# 4. SECRETS, CERTIFICATES & KEYS (CRITICAL SECURITY)
# ------------------------------------------------------------------------------
# Android Keystores
*.jks
*.keystore
# Apple Provisioning Profiles & Keys
*.p8
*.p12
*.key
*.mobileprovision
*.pem
*.cer
*.cert
AuthKey_*.p8

# ------------------------------------------------------------------------------
# 5. ENVIRONMENT VARIABLES (CRITICAL SECURITY)
# ------------------------------------------------------------------------------
# Blocks all variations of environment variables from leaking
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
# Explicitly whitelist example templates so team members know what keys are needed
!.env.example
!.env.template

# ------------------------------------------------------------------------------
# 6. SUPABASE & DENO EDGE FUNCTIONS
# ------------------------------------------------------------------------------
# Do NOT ignore supabase/functions/ (your Edge code), but DO ignore local state.
supabase/.temp/
supabase/.branches/
supabase/db/data/
supabase/.env
supabase/.env.*




# Deno Cache (Used for Edge Functions)
.deno/
vendor/

# ------------------------------------------------------------------------------
# 7. IDEs & EDITORS
# ------------------------------------------------------------------------------
# VS Code (Ignores settings.json and workspace configs)
.vscode/
# JetBrains / WebStorm / Android Studio
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Xcode Local User Data
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# ------------------------------------------------------------------------------
# 8. TYPESCRIPT & COMPILER OUTPUT
# ------------------------------------------------------------------------------
*.tsbuildinfo
out/
build/

# ------------------------------------------------------------------------------
# 9. LINTING & TESTING CACHES
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
.eslintcache
.stylelintcache
.prettiercache

# ------------------------------------------------------------------------------
# 10. OS GENERATED FILES
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# 11. GENERAL LOGS
# ------------------------------------------------------------------------------
*.log
logs/