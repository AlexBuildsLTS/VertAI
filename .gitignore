# ==============================================================================
# VERT AI — ENTERPRISE .GITIGNORE
# Architecture: Expo SDK 55, Supabase, React Native 0.83, Node.js
# ==============================================================================

# --- 1. DEPENDENCIES ---
node_modules/
.pnp
.pnp.*
.deno/
vendor/
deno.lock

# --- 2. EXPO & NATIVE ARTIFACTS ---
.expo/
dist/
web-build/
ios/
android/
.eas/
.kotlin/
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision

# --- 3. SUPABASE (LOCAL STATE & SECRETS) ---
# Ignore internal Supabase CLI state and local DB data
supabase/.temp/
supabase/.branches/
supabase/.env*
supabase/db/data/
# Explicitly whitelist critical infrastructure
!supabase/functions/
!supabase/seed.sql
!supabase/config.toml

# --- 4. ENVIRONMENT & SECRETS (CRITICAL) ---
.env
.env.*
.env.local
!.env.example

# --- 5. AI & TOOLING ARTIFACTS (CLEANUP) ---
.claude/
.gemini/
.remember/
*.GEMINI.md
*.md
# Specifically ignore the DB audit reports and structure files
*.supabase-db-audit-report.md
.STRUCTURE.md
STRUCTURE.md
GEMINI.md
.GEMINI.md

repomix-output.xml
repomix-output.md
# Whitelist essential documentation
!README.md

# --- 6. IDE & OS ARTIFACTS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.tsbuildinfo

# --- 7. LOGS & TEMPORARY FILES ---
*.log
logs/
temp/
tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# --- 8. EXPO CLI GENERATED ---
expo-env.d.ts
