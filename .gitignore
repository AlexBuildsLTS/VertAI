# ==============================================================================
# NORTH STUDIO — CLEAN ENTERPRISE .GITIGNORE
# Targets: Expo v55, Supabase, Deno, Root Environment
# ==============================================================================

# --- 1. DEPENDENCIES ---
node_modules/
.pnp
.pnp.*
.deno/
vendor/
deno.lock

# --- 2. EXPO & NATIVE ---
.expo/
dist/
web-build/
ios/
android/
.eas/
.kotlin/
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision

# --- 3. SUPABASE (LOCAL STATE & SECRETS) ---
# Ignore internal Supabase CLI state
supabase/.temp/
supabase/.branches/
supabase/.env*
# Ignore local DB data if using local persistence
supabase/db/data/
# Whitelist your code
!supabase/functions/
!supabase/seed.sql
!supabase/config.toml

# --- 4. ENVIRONMENT & SECRETS (CRITICAL) ---
.env
.env.*
.env.local
!.env.example

# --- 5. AI & TOOLING ARTIFACTS (CLEANUP) ---
.claude/
.remember/
*.GEMINI.md
*.md
# Specifically ignore the DB audit reports you mentioned
*.supabase-db-audit-report.md

# --- 6. IDE & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.tsbuildinfo

# --- 7. LOGS & TEMPS ---
*.log
logs/
temp/
tmp/